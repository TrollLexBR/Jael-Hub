--!grant RuntimeLoadstring
--!grant Filesystem

-- Jael Hub Loader
-- Detects the current game by UniverseId (game.GameId) so every place in a
-- multi-place universe loads the same script. Falls back to PlaceId so single
-- place scripts keep working.
-- Repo layout: RbxCli/Games/<gameId>  (preferred)  or  RbxCli/Games/<placeId>

local HttpService = game:GetService("HttpService")

local BASE = "https://raw.githubusercontent.com/TrollLexBR/Jael-Hub/refs/heads/main/RbxCli/Games/"

local function httpGet(url)
    local ok, res = pcall(function()
        return HttpService:RequestAsync({ Method = "GET", Url = url })
    end)
    if not ok then return nil, tostring(res) end
    if not res.Success then
        return nil, ("HTTP %d %s"):format(res.StatusCode, tostring(res.StatusMessage))
    end
    return res.Body
end

local gameId = game.GameId   -- UniverseId: shared by all places in the game
local placeId = game.PlaceId  -- unique per place

-- Try UniverseId first (one script for the whole game), then PlaceId.
local body, err
for _, id in ipairs({ gameId, placeId }) do
    body, err = httpGet(BASE .. tostring(id))
    if body then break end
end

if not body then
    warn(("[Jael Hub] No script for GameId %d / PlaceId %d (%s)")
        :format(gameId, placeId, tostring(err)))
    return
end

local fn, loadErr = rbxcli.loadstring(body)
if not fn then
    warn("[Jael Hub] Failed to compile script: " .. tostring(loadErr))
    return
end

local ok, runErr = pcall(fn)
if not ok then
    warn("[Jael Hub] Script error: " .. tostring(runErr))
    return
end

print(("[Jael Hub] Loaded script (GameId %d / PlaceId %d)"):format(gameId, placeId))
